# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any OpenRouter model slug. Defaults to a current Claude model.
COACH_MODEL=anthropic/claude-sonnet-4.6

# Port for the local server (serves the app + AI proxy).
PORT=8080

# Optional: override the OpenRouter endpoint (e.g. a self-host or test mock).
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
